---
/**
 * Background global con imagen + overlays para mantener legibilidad.
 * Usamos og-cover porque ya existe en /public/og/og-cover.png
 */
const { image = "/og/og-cover.png" } = Astro.props;
---

<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
  <!-- Imagen -->
  <div
    class="absolute inset-0 bg-cover bg-center opacity-20 blur-[2px] scale-105"
    style={`background-image: url('${image}');`}
  ></div>

  <!-- Overlay oscuro principal (evita que el fondo “coma” el texto) -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/85 via-black/70 to-black/90"></div>

  <!-- Vignette suave para bordes (look premium) -->
  <div
    class="absolute inset-0"
    style="background-image: radial-gradient(60% 50% at 50% 15%, rgba(0,0,0,0) 0%, rgba(0,0,0,0.65) 60%, rgba(0,0,0,0.92) 100%);"
  ></div>
</div>
